void AssemblySetup(){
      //This moves the servos to where the shoulde servo is tangent with the body, the elbow is horizontal, and the wrist is vertical

      rotateToAngle(0, Vector3 (90,90,90));
      rotateToAngle(1, Vector3 (90,90,90)); 
      rotateToAngle(2, Vector3 (90,90,90)); 
      rotateToAngle(3, Vector3 (90,90,90)); 
      rotateToAngle(4, Vector3 (90,90,90)); 
      rotateToAngle(5, Vector3 (90,90,90));  


}